# Copy to `.env` / `.env.local` and adjust. Never commit real secrets.

# POST /api/leads/import: required header `x-ccc-scanner-token` must match this value.
LEAD_IMPORT_API_TOKEN=change-me

# Scanner app base URL. `npm run dev` defaults to port 3020.
NEXT_PUBLIC_SCANNER_BASE_URL=http://localhost:3020
CCC_SCANNER_BASE_URL=http://localhost:3020

# CMS base URL used when a confirmed scanner outreach lead converts into a CMS claim.
CLAIMS_INTAKE_BASE_URL=http://localhost:3000

# Lead Scanner contact enrichment (POST JSON). Default matches local Lead Scanner app.
LEAD_SCANNER_ENRICH_URL=http://127.0.0.1:8000/api/enrich-business-contact

# Optional default SMTP sender.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=claims@saminourilawfirm.com
SMTP_PASS=replace-with-app-password
SMTP_FROM=claims@saminourilawfirm.com

# Dedicated outreach sender for recovery offer emails.
OUTREACH_SMTP_HOST=smtp.gmail.com
OUTREACH_SMTP_PORT=465
OUTREACH_SMTP_USER=claims@claimsreviewcenter.com
OUTREACH_SMTP_PASS=replace-with-outreach-app-password
OUTREACH_SMTP_FROM="Sami Nouri Law Firm <claims@claimsreviewcenter.com>"
